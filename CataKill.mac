Sub Event_Catacomb_A
	/message \ayYou have received an expedition for \am[\atCatacombs of Dranik (Azia)\am]\ar - BOO - Leaving !\ax
	/squelch /e3bcgza /dzquit
	/delay 1s
	/varset DranikCExpedition 0
	/varset CurrentExpedition NULL
	/delay 1s
	|/echo DranikCExpedition=(${DranikCExpedition}) | CurrentExpedition=(${CurrentExpedition})
	/message \ar - WRONG EXPEDITION !
	/say catacombs
	/doevents flush Catacomb_A
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Event_Catacomb_B
	/message \ayYou have received an expedition for \am[\atCatacombs of Dranik (Beza)\am]\ar - BOO - Leaving !\ax
	/squelch /e3bcgza /dzquit
	/delay 1s
	/varset DranikCExpedition 0
	/varset CurrentExpedition NULL
	/delay 1s
	|/echo DranikCExpedition=(${DranikCExpedition}) | CurrentExpedition=(${CurrentExpedition})
	/message \ar - WRONG EXPEDITION !
	/say catacombs
	/doevents flush Catacomb_B
/return
|--------------------------------------------------------
|--------------------------------------------------------
Sub Event_Catacomb_C
	/message \ayYou have received an expedition for \am[\atCatacombs of Dranik (Caza)\am]\ag - WOOT WOOT WOOT !\ax
	/varset DranikCExpedition 1
	/varset CurrentExpedition ${Window[DynamicZoneWnd].Child[DZ_CurrentDZValue].Text}
	/delay 1s
	|/echo DranikCExpedition=(${DranikCExpedition}) | CurrentExpedition=(${CurrentExpedition})
	/message \ag + CORRECT EXPEDITION !
	/doevents flush Catacomb_C
/return
