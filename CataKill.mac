	/varset DranikCLootArray[1,24] Shattered Visage
	/varset DranikCLootArray[1,25] Shimmering Ukun Hide
	/varset DranikCLootArray[1,26] Sleek Bat Fur
	/varset DranikCLootArray[1,27] Sparse Rat Fur
	/varset DranikCLootArray[1,28] Splintered Bone Necklace
	/varset DranikCLootArray[1,29] Starflow Stone
	/varset DranikCLootArray[1,30] Stone Shard
	/varset DranikCLootArray[1,31] Tattered Ikaav Braid
	/varset DranikCLootArray[1,32] Torn Rat Ear
	/varset DranikCLootArray[1,33] Ukun Guts
	/varset DranikCLootArray[1,34] Wiry Rat Whiskers
	/varset DranikCLootArray[1,35] Stolen Dragorn Clan Insignia
