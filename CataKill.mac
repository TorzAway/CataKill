	/varset DranikCLootArray[1,5] Cracked Stone Eye
	/varset DranikCLootArray[1,6] Curled Rat Foot
	/varset DranikCLootArray[1,7] Diamond
	/varset DranikCLootArray[1,8] Diamond Coin
	/varset DranikCLootArray[1,9] Dragorn Claw
	/varset DranikCLootArray[1,10] Dragorn Eye
	/varset DranikCLootArray[1,11] Dragorn Fang
	/varset DranikCLootArray[1,12] Dragorn Wing Bones
	/varset DranikCLootArray[1,13] Emerald
	/varset DranikCLootArray[1,14] Fire Emerald
	/varset DranikCLootArray[1,15] Gnarled Rat Tail
	/varset DranikCLootArray[1,16] Murkglider Sinew
