CataKill.mac - by Kroaking
Last Updated: April 6th, 2026 - 02:34:00 PM

v2.1.7

****************************************************************************************************************|
/squelch /log on
#chat group

#Event Catacomb_A "#*#Should you come across a dragorn known as Dragorn Marshal Greshka#*#"
#Event Catacomb_B "#*#Should you come across a noc known as Elite Overlord Vijaz#*#"
#Event Catacomb_C "#*#Should you come across a noc known as the Master of the Watch#*#"

#Event CantSee "You cannot see your target."
#Event TooFar  "Your target is #*#, get closer!"
#Event CantHit "You can't hit them from here."

#Event BagsFull "#*#There was no place to put that#*#"
#Event BagsFull "#*#There are no open slots for the held item in your inventory#*#"

#event NavMeshReload "#*#Could not locate destination on navmesh#*#"

#event TurboLootDone "#*# tells the group, '[DONE LOOTING]'#*#"

#define /message "/echo \ay[\atCataKill\ay]\aw "

| --------------------------------------------------------------------------------------------
Sub Main
	/if (${Debugging}) /echo Sub Main Entry

	/declare StuckSpamTimerSet	timer		outer	0
	/declare StuckSpamTrigger	timer		outer	0
	/declare OutX1 				int 		outer 	${Me.X}
	/declare OutY1 				int 		outer	${Me.Y}
	/declare OutZ1				int			outer	${Me.Z}
	/declare StuckCountOut 		int 		outer	0
	/declare BackUpTimer		int			outer 	0
	/declare GroupWaitTimer		int			outer	0
	/declare StuckSwitch		int 		outer
	/declare runcounter 		int 		outer	0
	/declare notkillable		int 		outer	0
	/declare Announce			bool		outer	FALSE
	/declare CurrentExpedition 	string		outer	NULL
	/declare ExpeditionDesc 	string		outer	NULL
	/declare version			string		outer	2.1.7
	/declare LastUpdated		string		outer	"Last Updated: April 6th, 2026 - 02:34:00 PM"
	
	/message ==================================================================
 	/call Declares
	/message ==================================================================
	/message \at${MacroName}.mac \aw- \atv${version} \awby \ag Kroaking
	/message \at${LastUpdated}.
	/message ==================================================================
	/delay 2s
	
	|----------------
	/call CheckThings
	|----------------	
		
	|------------------------------------------------------------------------------------------------------
	|------------
	/if (${GrpHasBRDClass}) {
		/message \ag- BRDMelodyName \ayis set to \am[\at${BRDMelodyName}\am]\ax
		/message \ag- BRDTravelSongSlot \ayis set to \am[\at${BRDTravelSongSlot}\am]\ax
	}
	|------------	
	/message \ag- CheckBots \ayis set to \am[\at${CheckBots}\am]\ax
	/message \ag- DoBurns \ayis set to \am[\at${DoBurns}\am]\ax
	/message \ag- LootCorpse \ayis set to \am[\at${LootCorpse}\am]\ax
	/message \ag- LootMethod \ayis set to \am[\at${LootMethod}\am]\ax
	/message \ag- RepeatMission \ayis set to \am[\at${RepeatMission}\am]\ax
	/message \ag- UseClickBuffs \ayis set to \am[\at${UseClickBuffs}\am]\ax
	/message \ag- UseClickDamage \ayis set to \am[\at${UseClickDamage}\am]\ax	
	
	|--------------------------------------------
	/if (${MouseLock}) {
		/message \ag- MouseLock \ayis set to \am[\at${MouseLock}\am]\ax
		/message \ag- MouseLock \aoCoordinates: \am[\atX=${MouseLocValX}, Y=${MouseLocValY}\am]\ax
		/mouseto ${MouseLocValX}, ${MouseLocValY}
	}
	|--------------------------------------------	
	
	|------------
	/if (${LootMethod.Equal[TURBOLOOT]})  {
		/message \ag- TurboLooter \ayis set to \am[\ao${TurboLooter}\am]\ax 
	}
	|------------
	
	/message ==================================================================
	
	|------------------------------------------------------------------------------------------------------
	/if (${SwarmPull}) {
		/message \ar***\at \agSwarmPull \arHigh Risk PULLING: \ayis set to \at[\ar${SwarmPull}}\at]
	} else {
		/message \ar***\at \agSwarmPull \arHigh Risk PULLING: \ayis set to \at[\ag${SwarmPull}}\at]
	}
	|------------------------------------------------------------------------------------------------------
	/if (${SwarmPull} && ${BiggerSwarms})  /message \ar***\at \agBiggerSwarms \arHigh Risk PULLING: \ayis set to \at[\ar${BiggerSwarms}\at]\ar.
	/if (${SwarmPull} && !${BiggerSwarms}) /message \ar***\at \agBiggerSwarms \arHigh Risk PULLING: \ayis set to \at[\ag${BiggerSwarms}\at]\ar.
	|------------------------------------------------------------------------------------------------------

	|-------------------------------------------------------------	
	/if ((${GrpHasENCClass} || ${GrpHasWIZClass}) && ${DoPBAOE}) {
		/message ==================================================================
		/message \ar ~ NOTE: \aoWe have \ayPBAE\ao classe(s) in group and \am[\atDoPBAOE\am]\ao is currently \am[\ar${DoPBAOE}\am]\ao.
		/message \ay ~ PBAE Mob count threshhold is currently at\ao: \am[\at${PBAOE_MobCount}\am]\ax
		/message ==================================================================	
		/delay 2s
	}
	|-------------------------------------------------------------
	
	/message ==================================================================
	/message \am- LastSwarmed_Step \ayis set to \at[\ag${LastSwarmed_Step}\at]\ax
	/message \am- CompletedPathTo \ayis set to \at[\ag${CompletedPathTo}\at]\ax
	/message ==================================================================
	/message \agGetting things ready, sit back...
	/delay 2s
	
	/message \ayI am currently in \am[\at${Zone.Name}\am]\ay.\ax
	|--------------
	/call GroupWait
	|--------------

	|----------------------
	/if (!${Select[${Zone.ID},152,202,386,336,330]}) {
		/message \ayLooks like we are \am[\atnot in a valid starting zone\am]\ay for ${MacroName} zone routing.\ax
		/call GoToMarrs
	}
	|----------------------
	
	|----------------------
 	/if (${startZone}==${Nexus}) /call GoToDranikFromNexus
	|----------------------

	|----------------------
 	/if (${startZone}==${PlaneofKnowledge}) /call GoToDranikFromPoK
	|----------------------

	|----------------------
 	/if (${startZone}==${TempleofMarr}) /call GoToDranikFromMarr
	|----------------------

	|------------------------------------------------------------------------------
	/if (${startZone}==${RuinedCityofDranik}) {
		/call GetExpeditionData
		|-------------------
		/if (${DranikCExpedition}==1) {
			/message ==================================================================
			/message \ag+\ay I currently \agHAVE\ay an expedition assigned to me - \am[\at${CurrentExpedition}\am].\ax
			/message ==================================================================
			/call GroupWait
			/call GoToExpedition
		} else {
			/message ==================================================================
			/message \ar-\ay I currently \arDO NOT HAVE\ay an expedition assigned to me !
			/message \ayI am headed to \am[\atGrand Historian Rygua\am]\ay to get an expedition.\ax
			/message ==================================================================
			/call GroupWait
			/call GotoRecruiter
		}
		|-------------------
	}
	|------------------------------------------------------------------------------

	| --- MAIN ------------------------------------------------------------------------------
	:mainloop	
	|---------
	/if (${Me.XTarget} || ${Bool[${Spawn[npc radius 35].Aggressive}]}) /call DoClearTargets
	|---------
	
	|--------------------------------------------
	|----------------------	 IF IN CATACOMB-C
	|--------------------------------------------
	/if (${Zone.ID}==${CataCombC}) {
		/if (${Me.XTarget}) /call DoClearTargets
		/message \ayI am currently in \am[\atCatacombs of Dranik (Caza)\am]\ay.\ax

		|----------------------------
		| ENGINE SELECT -- START
		|----------------------------
		|---- SwarmPull ----
		|----------------------------
		/if (${SwarmPull})  {
			/message ==================================================================
			/message \atCataKill \aw<\ar*\ao*\ay*\ag*\at*\au*\am*\ap*\aw> \ayABOUT TO: - \arSWARM PULL\ay . . . get ready! \aw<\ap*\am*\au*\at*\ag*\ay*\ao*\ar*\aw>
			/popcustom 13 5 ---> ABOUT TO SWARM PULL . . . get ready! <---
			/message ==================================================================
			/delay 3s
			|-----------------------------------
			| -- Call check mission zone.
			|-----------------------------------
			/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
			|-------------------------While
			/while (${InADungeon}==1) && ${DranikCExpedition}==1) {
				/if (${Me.XTarget} || ${Bool[${Spawn[npc radius 35].Aggressive}]}) /call DoClearTargets
				/if (${LootCorpse} && !${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) /call CheckForCorpses
				|------------------------------------------
				/if (!${CompletedPathTo}) {
					/call DoSwarmPull_PathTo
				} else {
					|------------------------------------------------------
					/if (!${BiggerSwarms}) {
						/call DoSwarmPull_MainLoop
					} else {
						/call DoSwarmPull_MainLoop_Bigger
					}
					|------------------------------------------------------
				}
				|------------------------------------------
				/if (${Me.XTarget}) /call DoClearTargets
				/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
				/call GMCheck
				/doevents
			}
			|-------------------------While
			/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
		} else {
		|----------------------------
		|---- SinglePull ----
		|----------------------------
			/message ==================================================================
			/message \atCataKill \aw<\ar*\ao*\ay*\ag*\at*\au*\am*\ap*\aw> \ayABOUT TO: - \agSINGLE PULL\ay . . . get ready! \aw<\ap*\am*\au*\at*\ag*\ay*\ao*\ar*\aw>
			/popcustom 15 5 ---> ABOUT TO SINGLE PULL . . . get ready! <---
			/message ==================================================================
			/delay 3s
			/varset PullRange ${CampRadius}
			|-----------------------------------
			| -- Call check mission zone.
			|-----------------------------------
			/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
			|-------------------------While
			/while (${InADungeon}==1 && ${DranikCExpedition}==1) {	
				/if (${Me.XTarget} || ${Bool[${Spawn[npc radius 35].Aggressive}]}) /call DoClearTargets			
				/if (${LootCorpse} && !${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) /call CheckForCorpses
				/call DoSinglePull
				/if (${Me.XTarget}) /call DoClearTargets
				/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
				/call GMCheck
				/doevents
			}
			|-------------------------While
			/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
		}
		|----------------------------
		| ENGINE SELECT -- END
		|----------------------------
	}
	|--------------------------------------------
	|----------------------	 IF IN CATACOMB-C
	|--------------------------------------------

	|--------------------------------------------
	|----------------------	 IF IN DRANIK
	|--------------------------------------------
	/if (${Zone.ID}==${RuinedCityofDranik}) {
		/call GetExpeditionData
		|-------------------
		/if (${DranikCExpedition}==0) {
			/message ==================================================================
			/message \ar-\ay I currently \arDO NOT HAVE\ay an expedition assigned to me !
			/message \ayI am headed to \am[\atGrand Historian Rygua\am]\ay to get an expedition.\ax
			/message ==================================================================
			/call GroupWait
			/call GotoRecruiter
		}
		|-------------------
	}
	|--------------------------------------------
	|----------------------	 IF IN DRANIK
	|--------------------------------------------
	
	/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
	/doevents
	/delay 1s
	/goto :mainloop
	| --- MAIN ------------------------------------------------------------------------------
	
	/if (${Debugging}) /echo Sub Main Exit

/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Declares
| --------------------------------------------------------------------------------------------
Sub Declares
	/if (${Debugging}) /echo Sub Declares Entry

	|==================== DO NOT ALTER THESE VALUES ====================
	/declare FarmMob 			string outer
	/declare PullRange 			int outer
	/declare MacroName			string	outer	CataKill
	/declare IniFileName		string	outer	${MacroName}_${Me.CleanName}.ini
	/declare FirstRun			int		outer	0

	|--------------------------------------
	/if (!${Ini[${IniFileName}].Length}) /varset FirstRun 1
	|--------------------------------------

	/message \ay${IniFileName} is the INI being used.
	/declare BagsAreFull		bool 	outer FALSE
	/declare CampX 				int 	outer ${Me.X}
	/declare CampY 				int 	outer ${Me.Y}
	/declare CampZ 				int 	outer ${Me.Z}
	/declare DebugRepeatTimer 	timer 	outer 1s
	/declare Endmac 			bool 	outer FALSE
	/declare PBAE_State			bool	outer FALSE
	/declare PauseForTurboloot	bool 	outer FALSE
	/declare SitDelay 			timer 	outer 5s
	/declare Targets 			string 	outer
	/declare TurboLootPause		bool	outer FALSE
	/declare courseCorrection 	timer 	outer 1s
	/declare myTargetID 		int 	outer 0
	/declare reportTarget 		timer 	outer 5s
	/declare startZone 			int 	outer ${Zone.ID}
	
	|** SPECIFIC of CataKill.mac/SwarmPull declares **|
	|----------------------------------------------------------
	/declare ZoneCount				int		outer 	0
	|----------------------------------------------------------

	|----------------------------------------------------------
	/declare InADungeon				int		outer	0
	/declare CurrentDC				int		outer	0
	/declare CurrentDCAC			int		outer	0
	/declare DranikCExpedition		int		outer	0
	|--------------------------------------
		
	|----------------------------------------------------------
	|** SPECIFIC of CataKill.mac/SwarmPull declares **|

	|** Declare colors their escape code for read-ability **|
	/declare Black 			string outer \ab
	/declare Blue   		string outer \au
	/declare Brown      	string outer \a-o
	/declare Cyan   		string outer \at
	/declare Gray			string outer \a-w
	/declare Green			string outer \ag
	/declare Pink   		string outer \am
	/declare Orange   		string outer \ao
	/declare Purple   		string outer \ap
	/declare Red   			string outer \ar
	/declare Teal   		string outer \at
	/declare White   		string outer \aw
	/declare Yellow  		string outer \ay
	/declare DarkGreen 		string outer \a-g
	/declare DarkMarroon	string outer \a-m
	/declare DarkPurple		string outer \a-p
	/declare DarkRed		string outer \a-r
	/declare DarkCyan		string outer \a-t
	/declare DarkBlue		string outer \a-u
	/declare DarkYellow		string outer \a-y
	|** End color declarations **|

	|** E3LDON.mac/PullFarm.mac type declares INIThings **|

	|** SPECIFIC of CataKill.mac/PullFarm.mac type declares **|
	/call CheckINI ${IniFileName} General Debugging bool FALSE
	/call CheckINI ${IniFileName} Camp CampRadius int 2500
	/call CheckINI ${IniFileName} Pull ZRadius int 500
	|** SPECIFIC of CataKill.mac/PullFarm.mac type declares **|

	/call CheckINI ${IniFileName} General AssistMe bool TRUE
	/call CheckINI ${IniFileName} General BiggerSwarms bool FALSE
	/call CheckINI ${IniFileName} General CheckBots bool TRUE
	/call CheckINI ${IniFileName} General DoBurns bool FALSE
	/call CheckINI ${IniFileName} General DoInvis bool TRUE
	/call CheckINI ${IniFileName} General DoPBAOE bool FALSE
	/call CheckINI ${IniFileName} General DoRogueSosCoh bool FALSE	
	/call CheckINI ${IniFileName} General GroupNavToMe bool TRUE	
	/call CheckINI ${IniFileName} General LootCorpse bool FALSE
	/call CheckINI ${IniFileName} General LootMethod string E3	
	/call CheckINI ${IniFileName} General LootTradeMats bool FALSE
	|--------------------------------------
	/if (${LootTradeMats}) {
		/declare DranikCLootArray[1,45]		outer		
	} else {
		/declare DranikCLootArray[1,37]	string	outer		
	}
	|--------------------------------------
	/call CheckINI ${IniFileName} General MouseLock bool TRUE
	/call CheckINI ${IniFileName} General MouseLocValX int 290
	/call CheckINI ${IniFileName} General MouseLocValY int 550
	/call CheckINI ${IniFileName} General PBAOE_MobCount int 5
	/call CheckINI ${IniFileName} General ReclaimDC bool FALSE
	/call CheckINI ${IniFileName} General RepeatMission bool TRUE
	/call CheckINI ${IniFileName} General SwarmPull bool FALSE
	/call CheckINI ${IniFileName} General UseClickBuffs bool FALSE
	/call CheckINI ${IniFileName} General UseClickDamage bool FALSE
	|------------------------------------------------------------
	/declare BRDTravelSong string  outer "Selo's Song of Travel"
	/call CheckINI ${IniFileName} BardSong BRDTravelSongSlot string 11
	/call CheckINI ${IniFileName} BardSong BRDMelodyName string base
	|------------------------------------------------------------
	/call CheckINI ${IniFileName} Pull PullAbility string ReplaceMeWithYourSkill
	/call CheckINI ${IniFileName} Pull PullAbilityRange int 30
	/call CheckINI ${IniFileName} Pull PullRequiresLineOfSight bool TRUE
	/call CheckINI ${IniFileName} Pull UseCastSpells bool FALSE
	|------------------------------------------------------------
	/call CheckINI ${IniFileName} Endurance MedEndAt int 8
	/call CheckINI ${IniFileName} Endurance MedEndTill int 100
	|------------------------------------------------------------
	/call CheckINI ${IniFileName} Mana MedAt int 30
	/call CheckINI ${IniFileName} Mana MedTill int 100
	/call CheckINI ${IniFileName} Mana BardMed bool TRUE
	|------------------------------------------------------------
	/call CheckINI ${IniFileName} Alerts AFKGM bool TRUE
	/call CheckINI ${IniFileName} Alerts UseBeep bool TRUE
	|------------------------------------------------------------
	/call CheckIni ${IniFileName} Theme LastSwarmed_Dungeon string NONE
	/call CheckIni ${IniFileName} Theme LastSwarmed_Step string 1
	/call CheckIni ${IniFileName} Theme CompletedPathTo bool FALSE
	|------------------------------------------------------------

	|------------------------------------------------------------------------------------------------------------
	| Set Turbolooter to the pulled variablie from Mq2Mono Query.
	|------------------------------------------------------------------------------------------------------------
	/declare TurboLooter	string	outer	${MQ2Mono.Query[e3,E3Bots(${Me.CleanName}).Query(GrpMainLooterName)]}
	|------------------------------------------------------------------------------------------------------------	

	|** End of LDON.mac/PullFarm.mac type declares **|

	|** Start ZoneID as variable **|
	/declare Nexus				int	outer 152
	/declare PlaneofKnowledge 	int outer 202
	/declare TempleofMarr 		int outer 386
	/declare RuinedCityofDranik	int outer 336
	|** Start ZoneID as variable **|

	|** Catacombs of Dranik (Caza) Zones **|
	/declare CataCombC 			int outer 330
	|** Catacombs of Dranik (Caza) Zones **|

	|** End ZoneID as Variable **|
	|==================== DO NOT ALTER THESE VALUES ====================

	|-------------------------------
	/if (${FirstRun}) {
		/message \ayCreated INI file \am[\at${IniFileName}\am]\ay with default values.\ax
		/message \ayPlease edit the file and restart \at${MacroName}.mac\ay.\ax
		/message \arEnding Macro !\ax
		/end
	} else {
		/message \ayConfig loaded from \am[\at${IniFileName}\am]\ay.\ax
	}
	|-------------------------------

	/if (${Debugging}) /echo Sub Declares Exit

/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CampInMarrs
| --------------------------------------------------------------------------------------------
Sub CampInMarrs
	/if (${Debugging}) /echo Sub CampInMarrs Entry
	/declare y int local 1
		
	/message \atWe are not set to repeat expeditions, Gating to Temple of Marr to camp !
	/message \ayI am headed to \am[\atTemple of Marr\am]\ay.\ax
	
	|---------------------
	|--- Group - GoToMarrs
	|---------------------
	/delay 10
	/squelch /e3bcgza /nav stop	
	/if (${GrpHasBRDClass}) /squelch /e3bct ${GrpBRDName} /playmelody stop
	/squelch /e3bcgza /keypress x
	/delay 6
	/squelch /e3bcgza /stand
	/delay 5
	/squelch /e3bcgza /alt act 511
	/delay 20s

	|----------------------------
	/while (${Group.Member[1].OtherZone} || ${Group.Member[2].OtherZone} || ${Group.Member[3].OtherZone} || ${Group.Member[4].OtherZone} || ${Group.Member[5].OtherZone}) {
		
		|--------------------------
		|--- Group - Start in Marrs
		|---------------------------
		/for y 1 to ${Group.Members} 
		/message \ayChecking status of: \at(\ag${Group.Member[${y}].Name}\at)\ay.
		/if (${Group.Member[${y}].OtherZone}) {
			/message \ar(${Group.Member[${y}].Name}) is NOT in ZONE !
			/squelch /e3bct ${Group.Member[${y}].Name} /nav stop
			/if (${Group.Member[${y}].Class.ShortName.Equal[BRD]}) /squelch /e3bct ${Group.Member[${y}].Name} /playmelody stop
			/squelch /e3bct ${Group.Member[${y}].Name} /keypress x
			/delay 5
			/squelch /e3bct ${Group.Member[${y}].Name} /stand
			/delay 5
			/squelch /e3bct ${Group.Member[${y}].Name} /alt act 511
			/delay 5
			/next y
		} else {
			/message \at(\ag${Group.Member[${y}].Name}\at)\ay is here.
			/delay 5
			/next y
		}
		|---------------------------
		/delay 20s
	}
	|----------------------------

	/while (${Zone.ID} != ${TempleofMarr}) {
		/delay 5s
	}
	/call GroupWait
	/delay 2s

	/if (${Zone.ID} == ${TempleofMarr}) /message \ayI am currently in \am[\atTemple of Marr\am]\ay.\ax
	/delay 3s
	|------------------------
	|--- Reset the Cycle Loop
	/call IniChange "Theme" "CompletedPathTo" "FALSE"
	/call ForceSpawnStepReset
	|------------------------
	/message \arCAMPING TO DESKTOP !!!\ax
	/squelch /e3bcgza /camp desktop
	/delay 3s
	/end

/if (${Debugging}) /echo Sub CampInMarrs Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToMarrs
| --------------------------------------------------------------------------------------------
Sub GoToMarrs
	/if (${Debugging}) /echo Sub GoToMarrs Entry
	/declare y int local 1
	
	/message \arOoops..   your not in a valid starting zone for macro, Gating to Temple of Marr !
	/message \ayI am headed to \am[\atTemple of Marr\am]\ay.\ax
	
	|---------------------
	|--- Group - GoToMarrs
	|---------------------
	/delay 10
	/squelch /e3bcgza /nav stop
	/if (${GrpHasBRDClass}) /squelch /e3bct ${GrpBRDName} /playmelody stop
	/squelch /e3bcgza /keypress x
	/delay 6
	/squelch /e3bcgza /stand
	/delay 5
	/squelch /e3bcgza /alt act 511
	/delay 20s

	|----------------------------
	/while (${Group.Member[1].OtherZone} || ${Group.Member[2].OtherZone} || ${Group.Member[3].OtherZone} || ${Group.Member[4].OtherZone} || ${Group.Member[5].OtherZone}) {
		
		|--------------------------
		|--- Group - Start in Marrs
		|---------------------------
		/for y 1 to ${Group.Members} 
		/message \ayChecking status of: \at(\ag${Group.Member[${y}].Name}\at)\ay.
		/if (${Group.Member[${y}].OtherZone}) {
			/message \ar(${Group.Member[${y}].Name}) is NOT in ZONE !
			/squelch /e3bct ${Group.Member[${y}].Name} /nav stop
			/if (${Group.Member[${y}].Class.ShortName.Equal[BRD]}) /squelch /e3bct ${Group.Member[${y}].Name} /playmelody stop
			/squelch /e3bct ${Group.Member[${y}].Name} /keypress x
			/delay 5
			/squelch /e3bct ${Group.Member[${y}].Name} /stand
			/delay 5
			/squelch /e3bct ${Group.Member[${y}].Name} /alt act 511
			/delay 5
			/next y
		} else {
			/message \at(\ag${Group.Member[${y}].Name}\at)\ay is here.
			/delay 5
			/next y
		}
		|---------------------------
		/delay 20s
	}
	|----------------------------
	/message \agAll group members are here.
	|----------------------------
	/while (${Zone.ID} != ${TempleofMarr}) {
		/delay 5s
	}
	/call GroupWait
	/delay 2s
	|----------------------------
	
	/if (${Zone.ID} == ${TempleofMarr}) /message \ayI am currently in \am[\atTemple of Marr\am]\ay.\ax
	/call GoToDranikFromMarr

	/if (${Debugging}) /echo Sub GoToMarrs Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToDranikFromMarr
| --------------------------------------------------------------------------------------------
Sub GoToDranikFromMarr
	/if (${Debugging}) /echo Sub GoToDranik Entry
	/declare y int local 1
	
	|------------------------------
	/if (${Zone.ID} == ${TempleofMarr}) {
		/message \ayI am headed to \am[\atThe Ruined City of Dranik\am]\ay.\ax
		/delay 3s
	
		|----------------------------
		/while (${Group.Member[1].OtherZone} || ${Group.Member[2].OtherZone} || ${Group.Member[3].OtherZone} || ${Group.Member[4].OtherZone} || ${Group.Member[5].OtherZone}) {
			
			|--------------------------
			|--- Group - Start in Marrs
			|---------------------------
			/for y 1 to ${Group.Members} 
			/message \ayChecking status of: \at(\ag${Group.Member[${y}].Name}\at)\ay.
			/if (${Group.Member[${y}].OtherZone}) {
				/message \ar(${Group.Member[${y}].Name}) is NOT in ZONE !
				/squelch /e3bct ${Group.Member[${y}].Name} /nav stop
				/if (${Group.Member[${y}].Class.ShortName.Equal[BRD]}) /squelch /e3bct ${Group.Member[${y}].Name} /playmelody stop
				/squelch /e3bct ${Group.Member[${y}].Name} /keypress x
				/delay 5
				/squelch /e3bct ${Group.Member[${y}].Name} /stand
				/delay 5
				/squelch /e3bct ${Group.Member[${y}].Name} /alt act 511		
			} else {
				/message \at(\ag${Group.Member[${y}].Name}\at)\ay is here.
			}
			/next y
			|---------------------------
			/delay 20s
		}
		|----------------------------
		/message \agAll group members are here.
		|----------------------------
		/squelch /e3bcgza /tar Klonopin
		/delay 5
		/squelch /e3bcgza /nav target
		/delay 5
		/while (${Navigation.Active}) {
			/call SetLoc
			/call CheckStuck
			/delay 5
		}
		/call GroupWait
		/delay 2s
		|----------------------------
		
		:BarkDranik1
		/if (${Target.CleanName.Equal[Klonopin]}) {
			/e3bark dranik	
		} else {
			/squelch /e3bcgza /tar Klonopin
			/delay 5
			/goto :BarkDranik1
		}
		/delay 2s
	}
	|------------------------------
	|---------------
	/while (${Zone.ID} != ${RuinedCityofDranik}) {
		/delay 5s
	}
	|---------------
	/call GroupWait
	/delay 2s
	
	/if (${Zone.ID} == ${RuinedCityofDranik}) /message \ayI am currently in \am[\atThe Ruined City of Dranik\am]\ay.\ax
	/call GotoRecruiter
	
	/if (${Debugging}) /echo Sub GoToDranik Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToDranikFromNexus
| --------------------------------------------------------------------------------------------
Sub GoToDranikFromNexus
/if (${Debugging}) /echo Sub GoToDranik Entry

|------------------------------
/if (${Zone.ID} == ${Nexus}) {
	/message \ayI am headed to \am[\atThe Ruined City of Dranik\am]\ay.\ax
	/delay 3s
	/squelch /e3bcgza /tar Valium
	/delay 5
	/squelch /e3bcgza /nav target
	/delay 5
	/while (${Navigation.Active}) {
		/call SetLoc
		/call CheckStuck
		/delay 5
	}
	/call GroupWait
	/delay 2s

	:BarkDranik2
	/if (${Target.CleanName.Equal[Valium]}) {
		/e3bark dranik	
	} else {
		/squelch /e3bcgza /tar Valium
		/delay 5
		/goto :BarkDranik2
	}
	/delay 2s
}
|------------------------------
|---------------
/while (${Zone.ID} != ${RuinedCityofDranik}) {
	/delay 5s
}
|---------------
/call GroupWait
/delay 2s

/if (${Zone.ID} == ${RuinedCityofDranik}) /message \ayI am currently in \am[\atThe Ruined City of Dranik\am]\ay.\ax
/call GotoRecruiter

/if (${Debugging}) /echo Sub GoToDranik Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToDranikFromPoK
| --------------------------------------------------------------------------------------------
Sub GoToDranikFromPoK
/if (${Debugging}) /echo Sub GoToDranikFromPoK Entry

|------------------------------
/if (${Zone.ID} == ${PlaneofKnowledge}) {
	/message \ayI am headed to \am[\atThe Ruined City of Dranik\am]\ay.\ax
	/delay 3s
	/squelch /e3bcgza /tar Valium
	/delay 5
	/squelch /e3bcgza /nav target
	/delay 5
	/while (${Navigation.Active}) {
		/call SetLoc
		/call CheckStuck
		/delay 5
	}
	/call GroupWait
	/delay 2s
	
	:BarkDranik3
	/if (${Target.CleanName.Equal[Valium]}) {
		/e3bark dranik	
	} else {
		/squelch /e3bcgza /tar Valium
		/delay 5
		/goto :BarkDranik3
	}
	/delay 2s
}
|------------------------------
|---------------
/while (${Zone.ID} != ${RuinedCityofDranik}) {
	/delay 5s
}
|---------------
/call GroupWait
/delay 2s

/if (${Zone.ID} == ${RuinedCityofDranik}) /message \ayI am currently in \am[\atThe Ruined City of Dranik\am]\ay.\ax
/call GotoRecruiter

/if (${Debugging}) /echo Sub GoToDranikFromPoK Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GotoRecruiter
| --------------------------------------------------------------------------------------------
Sub GotoRecruiter
	/if (${Debugging}) /echo Sub GotoRecruiter Entry
	|----------- Ruined City of Dranik ------------
	/if (${Zone.ID} == ${RuinedCityofDranik}) {
		|---------------
		/if (!${Defined[Recruiter]}) {
			/declare Recruiter string outer Grand Historian Rygua
			/declare RecruiterLoc string outer ${Spawn[${Recruiter}].Y} ${Spawn[${Recruiter}].X} ${Spawn[${Recruiter}].Z}
		}
		|---------------
		|/removelev
		|----------------------------------------------
		|/echo {Spawn[${Recruiter}].Distance3D}=(${Spawn[${Recruiter}].Distance3D})
		:RecruiterDistanceCheck
		/if (${Spawn[${Recruiter}].Distance3D} <= 15) {
			/message \agI am next to \am[\at${Recruiter}\am]\ay \ag getting an expedition...
			/call GetExpedition
		} else {
			|-------------
			/if (${Spawn[${Recruiter}].Distance3D} > 15) {
				/message \agGoing to \ay[\ap${Recruiter}\ay] \ag to pick up an expedition...
				/if (${DoInvis}) /call CheckInvis
				/delay 1s
				
				|------------------------------------------
				/if (${DoInvis}) {
					|---------------------- NO INVIS VNAV !
					/call NavToLoc3 ${RecruiterLoc}
					|---------------------- NO INVIS VNAV !
				} else {
					|---------------------- INVIS VNAV !
					/call NavToLoc2 ${RecruiterLoc}
					|---------------------- INVIS VNAV !				
				}
				|------------------------------------------

				/delay 5
				|-------------
				|-------------
				/while (${Navigation.Active}) {
					/call SetLoc
					/call CheckStuck
					/delay 20
				}
				|-------------
				/call Group2Me
				/call GroupWait
				/if (${Me.XTarget}) /call DoClearTargets
				/doevents
				/goto :RecruiterDistanceCheck
			}
		}
		|----------------------------------------------
	}
	|----------- Ruined City of Dranik ------------

	/if (${Debugging}) /echo Sub GotoRecruiter Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GetExpedition (Called from GetExpedition)
| --------------------------------------------------------------------------------------------
Sub GetExpedition
	/if (${Debugging}) /echo Sub GetExpedition Entry

	/message \agGettting an Expedition . . .

	:RequestExpedition
	/if (${Target.ID} != ${Spawn[${Recruiter}].ID}) /target id ${Spawn[${Recruiter}].ID}
	/delay 2s ${Target.ID} == ${Spawn[${Recruiter}].ID}
	/if (${Target.ID} != ${Spawn[${Recruiter}].ID}) /goto :RequestExpedition

	|----------------------------!
	/if (${Target.ID} == ${Spawn[${Recruiter}].ID}) {
		|--------------------------
		/delay 1s
		/say catacombs
		:WaitForCorrectExpedition
		|-------------------------------------------------------------------------------------------
		|----  DO NOT MESS WITH HE DELAYS BEFORE AND AFTER /DOEVETS OR IT WILL NOT PICKUP EVENT !!!!
		/delay 1s
		/doevents
		/delay 1s
		|----  DO NOT MESS WITH HE DELAYS BEFORE AND AFTER /DOEVETS OR IT WILL NOT PICKUP EVENT !!!!
		|-------------------------------------------------------------------------------------------
		/if (${DranikCExpedition}==0) /goto :WaitForCorrectExpedition

		|-------------------------------
		|--- Have an Expedition -- C !!!
		/if (!${CurrentExpedition.Length}==0 && ${CurrentExpedition.Find[Catacombs of Dranik]}) {
			/squelch /target clear
			/squelch /e3bcgza /keypress alt+z
			/message \ayGoing to the expedition now . . . .
			|------------------------
			|--- Reset the Cycle Loop
			|------------------------
			/if (${DoRogueSosCoh} && ${GrpHasROGClass}) {
				/call IniChange "Theme" "CompletedPathTo" "TRUE"
			} else {
				/call IniChange "Theme" "CompletedPathTo" "FALSE"
			}
			|------------------------
			/call ForceSpawnStepReset
			|------------------------
			/call GoToExpedition
		}
		|--- Have an Expedition -- C !!!
		|-------------------------------
	}
	|----------------------------

	/if (${Debugging}) /echo Sub GetExpedition Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToExpedition
| --------------------------------------------------------------------------------------------
Sub GoToExpedition
	/if (${Debugging}) /echo Sub GoToExpedition Entry

	/message \ayI am headed to: \am[\atCatacombs of Dranik (Caza)\am]\ag
	
	|--- CHECK INVIS !!!
	/if (${DoInvis}) /call CheckInvis
	|--- CHECK INVIS !!!
	/delay 1s
	|------------------------------------------
	/if (${DoInvis}) {
		|---------------------- NO INVIS VNAV !
		/call NavToLoc3 1019.45 -290.80 -75.26
		|---------------------- NO INVIS VNAV !
	} else {
		|---------------------- INVIS VNAV !
		/call NavToLoc2 1019.45 -290.80 -75.26
		|---------------------- INVIS VNAV !				
	}
	|------------------------------------------	
	/delay 5

	|-------------
	/while (${Navigation.Active}) {
		/call SetLoc
		/call CheckStuck
		/delay 20
	}
	|-------------
	/call Group2Me
	/call GroupWait
	/if (${Me.XTarget}) /call DoClearTargets
	/doevents
	|----------------------------------------
	|/squelch /e3bcgz /removelev
	/squelch /e3bcgz /doortarget CASTLESWITCH
	/delay 2s
	/squelch /e3bcgz /click left door
	|----------------------------------------
	|/squelch /removelev
	/squelch /doortarget CASTLESWITCH
	/delay 2s
	/squelch /click left door
	|----------------------------------------
	/call Zoning

	|----------------------------------------
	/if (${Zone.ID}==${CataCombC}) {		
		/if (${GrpHasBRDClass}) {
			/call ResetBard
			/delay 2s
		}
		/squelch /e3bcg /multiline ; /afollow off ; /nav stop ; /stand
		/delay 5
		/squelch /followoff
		/delay 5
		/squelch /dropinvis 
		/delay 5
		|/squelch /droplev
		|/delay 5
		/if (${DoRogueSosCoh} && ${GrpHasROGClass}) /call Rogue_SOS_COH
	}
	|----------------------------------------

	/if (${Debugging}) /echo Sub GoToExpedition Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: CheckExpeditionStatus
| --------------------------------------------------------------------------------------------------
Sub CheckExpeditionStatus
	/if (${Debugging}) /echo Sub CheckExpeditionStatus Entry

	|--------------------------------------------
	|--- GRAB THE CURRENT EXPEDITIOn DATA
	|--------------------------------------------
	/call CheckInADungeon
	/call CheckHaveDranikCExpedition
	/varset CompletedPathTo ${Ini[${IniFileName},Theme,CompletedPathTo]}
	|/echo InADungeon=(${InADungeon}) | CurrentExpedition=(${CurrentExpedition}) | DranikCExpedition=(${DranikCExpedition}) | CompletedPathTo=(${CompletedPathTo})
	|--------------------------------------------

	|-----------------------------------------------------------------
	| We are still in an ative expedition and in the expedition zone !
	|-----------------------------------------------------------------
	/if (${DranikCExpedition}==1 && ${InADungeon}==1) /return
	|-----------------------------------------------------------------

	|-----------------------------------------------------------------------
	|--- Expedition Over, but I haven't been booted out to Dranik yet !!!!
	|-----------------------------------------------------------------------
	:WaitTillIGetBooted
	/if (${DranikCExpedition}==0 && ${InADungeon}==1) {
		/message ==================================================================
		/message \ay - Looks like our expedition is over, but we havent been booted yet.\ax
		/message \ay - Waiting \am20\ay seconds until booted !\ax
		/message ==================================================================
		/if (!${Me.Combat} && !${Me.XTarget})  /delay 20s
		/call CheckInADungeon
		/if (${DranikCExpedition}==0 && ${InADungeon}==1) /goto :WaitTillIGetBooted
	}
	|-----------------------------------------------------------------------

	|-----------------------------------------------------------------------
	|--- Expedition Over, Already Booted out ... Get a new Expedition !
	|-----------------------------------------------------------------------
	/if (${DranikCExpedition}==0 && ${InADungeon}==0) {
		/message \ar-\ay I currently \arDO NOT HAVE\ay an expedition assigned to me !
		|-------------------
		/if ((${Zone.ID}==${RuinedCityofDranik}) && ${RepeatMission}) {
			|------------------------
			|--- Reset the Cycle Loop
			|------------------------
			/call IniChange "Theme" "CompletedPathTo" "FALSE"
			/call ForceSpawnStepReset
			|------------------------
			/message ==================================================================
			/message \ayI am headed to \am[\atGrand Historian Rygua\am]\ay to re-get an expedition.\ax
			/message ==================================================================
			/call GotoRecruiter
		}
		|-------------------
		/if (!${RepeatMission}) /call CampInMarrs
	}
	|-----------------------------------------------------------------------

	/if (${Debugging}) /echo Sub CheckExpeditionStatus Exit
	/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoClearTargets
| --------------------------------------------------------------------------------------------
Sub DoClearTargets
	/if (${Debugging}) /echo Sub DoClearTargets Entry
	
	/declare i 				int 	local	0
	/declare CurrentTarget 	int 	local	0
	
	|----------------------------------------------------------------------------------
	|-- Clear Target of PC or "Out of Range" NPC to pick up local 35 radius check mobs.
	|----------------------------------------------------------------------------------
	/if (${Target.ID} && (${Target.Type.Equal[pc]} || ${Target.Distance}>35)) {
		/if (${Target.ID} && (${Target.Type.Equal[pc]})) /message \ar~Initial~ \am[\atTarget\am]\ao ~ \am[\at${Target.CleanName}\am]\ao is a \am[\atPC\am]\ao, resetting target !\ax		
		/if (${Target.ID} && (${Target.Distance}>35)) /message \ar~Initial~ \am[\atTarget\am]\ao ~ \am[\at${Target.CleanName}\am]\ao is out of \am[\atLocal Range \am[\ay35\am]\am]\ao, resetting target !\ax
		/squelch /target /clear
	}
	|----------------------------------------------------------------------------------
	
	|--------------------------------------------------
	|-- MAIN DOCLEARTARGETS LOGIC
	|--------------------------------------------------
	/if (${Me.XTarget} || ${Bool[${Spawn[npc radius 35].Aggressive}]} || (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive})) {
		
		:gotoloopkeepfighting
		|------------------------
		/if (${Me.Sitting} || ${Me.Feigning}) /stand
		|------------------------
		
		|---------------------------------
		| Cler Target if Target is Corpse.
		|---------------------------------
		/if (${Target.Type.Find[corpse]}) {
			/squelch /target clear
		}
		|---------------------------------
		
		|--------------------------------------------------------------------------------------------------
		|-- Call PBAE_Enabled state detection if we have classe(s) and ${DoPBAOE}
		|--------------------------------------------------------------------------------------------------
		/if ((${GrpHasENCClass} || ${GrpHasWIZClass}) && ${DoPBAOE}) {
			|-------------------------------------
			/if (!${PBAE_State} && ${Target.ID} && ${Debugging}) {
				|-- Degub Condition
				/message ==================================================================
				/message \ayPBAE_DEBUGGER\ax
				/message \aoPBAE_State\ay=\am(\ag${PBAE_State}\am)\ao | \aoTargetID\ay=\am(\ag${Target.ID}\am)\ao | \aoTargetDistance\ay=\am(\ag${Target.Distance}\am)\ax
				/message \aoSpawnCount\ay=\am(\ag${SpawnCount[npc radius 25]}\am)\ao | \aoPBAOE_MobCount\ay=\am(\ag${PBAOE_MobCount}\am)\ao | \aoAggressive\ay=\am(\ag${Bool[${Spawn[npc radius 25].Aggressive}]}\am)\ax
				/message ==================================================================
			}
			|-------------------------------------
			/call CheckPBAELogic
		}
		|--------------------------------------------------------------------------------------------------
		
		|------------------------------
		|-- Dont have target, but aggressive mob near.
		|------------------------------
		/if (!${Target.ID} && ${Bool[${Spawn[npc radius 35].Aggressive}]}) {			
			|-----
			/if (!${Target.ID} && ${Navigation.PathExists[id ${Me.ID}]}) {
				/squelch /e3bcgz /nav id ${Me.ID}
			} else /if (!${Target.ID} && !${Navigation.PathExists[id ${Me.ID}]}) {
				/squelch /e3bcgz /moveto id ${Me.ID} mdist 10
			}
			|-----
			/delay 5
			/target id ${NearestSpawn[npc radius 35 targetable].ID}
			/delay 5
			|------------
			/if (${CurrentTarget}!=${NearestSpawn[npc radius 35 targetable].ID}) {
				/if (${Target.ID}!=0) /message \ayTargetting aggressive mob \aoID: \am[\at${NearestSpawn[npc radius 35 targetable].ID}\am] \aoName: \am[\at${NearestSpawn[npc radius 35 targetable].CleanName}\am]\ay and attacking !\ax
				/squelch /ClearTarget usemytarget
				/delay 5
				/varset CurrentTarget ${NearestSpawn[npc radius 35 targetable].ID}
			}
			|------------
		}
		|------------------------------
		
		|------------------------------
		|-- Have a target, kill it.
		|------------------------------
		/if (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive}) {				
			|-----
			/if (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive} && (${Target.Distance}>20) && ${Navigation.PathExists[id ${Target.ID}]}) {
				/squelch /nav id ${Spawn[npc fleeing].ID}
				/delay 5
				/squelch /e3bcgz /nav id ${Spawn[npc fleeing].ID}
			} else /if (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive} && (${Target.Distance}>20) && !${Navigation.PathExists[id ${Target.ID}]}) {
				/squelch /moveto id ${Spawn[npc fleeing].ID} mdist 10
				/delay 5
				/squelch /e3bcgz /moveto id ${Spawn[npc fleeing].ID} mdist 10
			}
			|-----
			/delay 5
			|------------
			/if (${CurrentTarget}!=${Target.ID}) {
				/if (${Target.ID}!=0) /message \ayTargetting aggressive mob \aoID: \am[\at${NearestSpawn[npc radius 35 targetable].ID}\am] \aoName: \am[\at${NearestSpawn[npc radius 35 targetable].CleanName}\am]\ay and attacking !\ax
				/squelch /ClearTarget usemytarget
				/delay 5
				/varset CurrentTarget ${Target.ID}
			}
			|------------
		}
		|------------------------------
		
		|------------------------------
		|-- RUNNER: Dont have target, Xtarget MOB may be fleeing.
		|------------------------------
		/if ((${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) || (${Me.XTarget} && ${Spawn[npc fleeing].ID}) || ${Spawn[npc fleeing].ID}) {

			|------------------------------
			/if (${Spawn[npc fleeing].ID}) {	
				|-----
				/if (${Spawn[npc fleeing].ID} && (${Spawn[npc fleeing].Distance}>20) && ${Navigation.PathExists[id ${Spawn[npc fleeing].ID}]}) {
					/squelch /nav id ${Spawn[npc fleeing].ID}
					/delay 5
					/squelch /e3bcgz /nav id ${Spawn[npc fleeing].ID}
				} else /if (${Spawn[npc fleeing].ID} && (${Spawn[npc fleeing].Distance}>20) && !${Navigation.PathExists[id ${Spawn[npc fleeing].ID}]}) {
					/squelch /moveto id ${Spawn[npc fleeing].ID} mdist 10
					/delay 5
					/squelch /e3bcgz /moveto id ${Spawn[npc fleeing].ID} mdist 10
				}
				|-----
				/delay 5			
				/target id ${Spawn[npc fleeing].ID}				
				/delay 5
				|------------
				/if (${CurrentTarget}!=${Spawn[npc fleeing].ID}) {
					/if (${Target.ID}!=0) /message \arFound a \am[\atRandom\am]\ar fleeing mob! \ayTargetting \aoID: \am[\at${Me.XTarget[${i}].ID}\am] \ayName\ao: \am[\at${Me.XTarget[${i}].CleanName}\am]\ay and attacking !\ax
					/squelch /ClearTarget usemytarget
					/delay 5
					/varset CurrentTarget ${Spawn[npc fleeing].ID}
				}
				|------------				
			}
			|------------------------------
			
			|------------------------------
			|-- Xtarget
			/if ((${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) || (${Me.XTarget} && ${Spawn[npc fleeing].ID})) {
				|-----
				/if (${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) {
					/message \aoAn XTarget mob is out of range, hunting it down !\ax
				}
				|-----

				|-----
				/if	(${Me.XTarget} && ${Spawn[npc fleeing].ID}) {
					/message \aoXTarget mob is fleeing, chasing it down !\ax
				}
				|-----				
			
				|------------------
				/if	(${Me.XTarget}) {
					/for i 1 to ${Me.XTargetSlots}
						/if (${Me.XTarget[${i}].ID}) {	
							|-----
							/if (${Me.XTarget} && (${Me.XTarget[${i}].Distance}>20) && ${Navigation.PathExists[id ${Me.XTarget[${i}].ID}]}) {
								/squelch /nav id ${Me.XTarget[${i}].ID}
								/delay 5
								/squelch /e3bcgz /nav id ${Me.XTarget[${i}].ID}
							} else /if (${Me.XTarget} && (${Me.XTarget[${i}].Distance}>20) && !${Navigation.PathExists[id ${Me.XTarget[${i}].ID}]}) {
								/squelch /moveto id ${Me.XTarget[${i}].ID}
								/delay 5
								/squelch /e3bcgz /moveto id ${Me.XTarget[${i}].ID}
							}
							|-----
							/delay 5			
							/target id ${Me.XTarget[${i}].ID}
							/delay 5		
							|------------
							/if (${CurrentTarget}!=${Me.XTarget[${i}].ID}) {
								/if (${Target.ID}!=0) /message \arFound a \am[\atXTarget\am]\ar fleeing mob! \ayTargetting \aoID: \am[\at${Me.XTarget[${i}].ID}\am] \ayName\ao: \am[\at${Me.XTarget[${i}].CleanName}\am]\ay and attacking !\ax
								/squelch /ClearTarget usemytarget
								/delay 5
								/varset CurrentTarget ${Me.XTarget[${i}].ID}
							}
							|------------
							/break
						}
					/next i
				}				
				|------------------
			}
			|------------------------------
		}
		|------------------------------
		|-- RUNNER
		|------------------------------	
		
		|------------------------------
		| Target Distance Stick Check
		|------------------------------
		/if (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive} && (${Target.Distance} > 20)) {	
			/if (${Target.ID}!=0) /message \ayMob \aoID: \am[\at${Target.ID}\am] \ag|\ax \aoName: \am[\at${Target.CleanName}\am]\ay \ag|\ax \aoDistance: \am[\at${Target.Distance}\am]\ay is \ar[TOO FAR AWAY]\ay, adjusting group !\ax
			|--
			/if (${Navigation.PathExists[id ${Target.ID}]}) {
					/squelch /nav id ${Target.ID}
					/delay 2s ${Target.Distance}<=20
					/squelch /e3bcgz /nav id ${Me.ID}					
				} else {
					/squelch /moveto id ${Target.ID} mdist 10
					/delay 2s ${Target.Distance}<=20
					/squelch /e3bcgz /moveto id ${Me.ID} mdist 10
			}
			|--
			/stick 15
			/delay 5
		} else {
			/stick 15
			/delay 5
		}
		|------------------------------

		|------------------------------
		| Target LineOfSight Check
		|------------------------------
		/if (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive} && !${Target.LineOfSight}) {	
			/if (${Target.ID}!=0) /message \ayMob \aoID: \am[\at${Target.ID}\am] \ag|\ax \aoName: \am[\at${Target.CleanName}\am]\ay \ag|\ax \aoDistance: \am[\at${Target.Distance}\am]\ay is \ar[NOT IN LINE OF SIGHT]\ay, adjusting group !\ax
			|---------------------
			/if (${Navigation.PathExists[id ${Target.ID}]}) {
					/squelch /nav id ${Target.ID}
					/delay 2s ${Target.LineOfSight}
					/squelch /face fast
					/squelch /e3bcgz /nav id ${Me.ID}					
				} else {
					/squelch /moveto id ${Target.ID} mdist 10
					/delay 2s ${Target.LineOfSight}
					/squelch /face fast
					/squelch /e3bcgz /moveto id ${Me.ID} mdist 10
			}
			|---------------------
		}		
		|------------------------------	
			
		|-------------------------- DO BURNS -----------------------------------------
        /if (${Target.ID} && ${Me.Combat} && ${Target.Type.Equal[npc]} && ${DoBurns}) {
			| --- Explosion of Spite
			/if (${SpawnCount[npc radius 50]} >2 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[749]}) {
				/alt act 749
				/if (${DoBurns}) /quickburn
				/if (${DoBurns}) /longburn
				/delay 20
				/goto :gotoloopkeepfighting
			}
			| --- Explosion of Hatred
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[822]}) {
				/alt act 822
				/if (${DoBurns}) /fullburn
				/delay 20
				/goto :gotoloopkeepfighting
			}
			| --- Projection of Doom
			/if (${SpawnCount[npc radius 50]} >6 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[3215]} && ${DoBurns}) /alt act 3215
			| --- EpicBurn
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${DoBurns}) /epicburn
			| --- Vicious Bite of Chaos
			/if ((${Me.PctHPs} < 95) && ${Cast.Ready[825]} && ${DoBurns})  /alt act 825
			| --- Chattering Bones
			/if (${Cast.Ready[3822]} && ${DoBurns}) /alt act 3822
			| --- Encroaching Darkness
			/if ((${SpawnCount[npc radius 50]} <3) && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[826]}) {
				/squelch /e3bcgz /nav target
				/assistme
				/alt act 826
			}
            /delay 2s
            /if (${Debugging}) /echo DEBUG: KillMob: Combat Loop

            /goto :gotoloopkeepfighting
        }
		|-------------------------- DO BURNS -----------------------------------------
		
		|--------------------------------------------------
		/if	(${Me.XTarget} || ${Bool[${Spawn[npc radius 35].Aggressive}]} || (${Target.ID} && ${Target.Type.Equal[npc]} && ${Target.Aggressive})) /goto :gotoloopkeepfighting
		|--------------------------------------------------
	}
	|--------------------------------------------------
	|-- MAIN DOCLEARTARGETS LOGIC
	|--------------------------------------------------

	|----------------------
	|--- Reset CurrentTarget
	|----------------------
	/varset CurrentTarget 0
	|----------------------
	
	|------------------------
	|-- FORCE TURN OFF PBAE
	|------------------------
	/if (${PBAE_State}) {			
			/varset PBAE_State FALSE
			/message \aoPBAE is currently \am[\arENABLED\am]\ao, disabling \am[\atPBAE\am]\ao now.\ax
			/pbaeoff
	}
	|------------------------
	
	|-----------------------------------
	/if (!${Me.XTarget} || (!${Target.ID} && !${Bool[${Spawn[npc radius 50].Aggressive}]})) /squelch /target clear
	|-----------------------------------
	/if (${Debugging}) /echo Sub DoClearTargets Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckPBAELogic
| --------------------------------------------------------------------------------------------
Sub CheckPBAELogic
	/if (${Debugging}) /echo CheckPBAELogic Sub Entry
	
	|-- TURN ON PBAE
	/if (!${PBAE_State} && ${Target.ID} && (${Target.Distance}<=25) && (${SpawnCount[npc radius 25]}>=${PBAOE_MobCount}) && ${Bool[${Spawn[npc radius 25].Aggressive}]}) {
		/varset PBAE_State TRUE
		/message \aoPBAE is currently \am[\agDISABLED\am]\ao: ~ \am[\arENABLING\am]\ao ~ \am[\atPBAE\am]\ao now.\ax
		/popcustom 13 2 -> PBAE ON <
		/pbaeon
	}
	|-- TURN OFF PBAE
	/if (${PBAE_State} && ${Target.ID} && (${Target.Distance}<=25) && (${SpawnCount[npc radius 25]}<${PBAOE_MobCount}) && ${Bool[${Spawn[npc radius 25].Aggressive}]}) {			
		/varset PBAE_State FALSE
		/message \aoPBAE is currently \am[\arENABLED\am]\ao: ~ \am[\agDISABLING\am]\ao ~ \am[\atPBAE\am]\ao now.\ax
		/popcustom 2 2 -> PBAE OFF <-
		/pbaeoff
	}
	|-------------------------------------------------------------

	/if (${Debugging}) /echo CheckPBAELogic Sub Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoSinglePull
| --------------------------------------------------------------------------------------------
Sub DoSinglePull(string Enemy)
	/if (${Debugging}) /echo DoSinglePull Sub Entry
	|-------------------------
	/call CheckCasting
	|-------------------------
	/varset CampX ${Me.X}
	/varset CampY ${Me.Y}
	/varset CampZ ${Me.Z}
	|--------------------
	/if (${Bool[${Enemy}]}) {
		/varset FarmMob ${Enemy}
		/if (${Debugging} && !${reportTarget}) {
			/message Looking for: ${FarmMob}
			/varset reportTarget ${reportTarget.OriginalValue}
		}
	} else /if (!${reportTarget}) {
		/message \arAttacking \ay[\apAnything I can get my grubby paws on\ay]\ar.
		/varset reportTarget ${reportTarget.OriginalValue}
		|--------------------
		/if (${myTargetID} && !${Target.Type.Equal[Corpse]} && !${Target.Type.Equal[Pet]} && !${Target.Type.Equal[PC]}) {
			/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
			|--------------------
			/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/squelch /attack on
				|/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) /pet attack
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			|--------------------
			/varcalc BackUpTimer (${BackUpTimer})+1
			|--------------------
			/if (${BackUpTimer}>7) {
				/message \ayHaving trouble getting to a target.. Attempting to get back on mesh.
				/if (${Debugging}) /echo Setting BackUpTimer Plus 1
				/call BackUp
				/varset BackUpTimer 0
			}
			|--------------------
			/if (${AssistMe}) {
				/if (${Debugging}) /e3bcgz (Line: ${Macro.CurLine}) killthis
				/squelch /e3bcgz /nav id ${Me.ID}
				/squelch /e3bcgz /target id ${Me.XTarget}
				/timed 10 /squelch /e3bcgz /assistme
				|/timed 15 /squelch /e3bcgz /pet attack
				|/timed 20 /squelch /e3bcgz /pet swarm
				
			}	
			|--------------------
		}
		|--------------------
	}
	|--------------------
	
	:findMob
	/if (${Debugging}) /echo FindMob DoSinglePull
	/if (${Target.Type.Equal[corpse]}) {
		/if (${Target.ID} == ${myTargetID}) /varset myTargetID 0
		/squelch /target clear
	}
	/if (${Window[RespawnWnd].Open}) /call GroupDeathChk
	/if (!${Me.XTarget} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}
	/if (${Debugging}) /echo \aymyTargetID has an ID: ${Spawn[id ${myTargetID}].ID} - is a corpse: ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} - I have an XTarget: !${Me.XTarget}
	/if (!${Spawn[id ${myTargetID}].ID} || ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} && !${Me.XTarget} && !${Me.Casting.ID}) {
		/message \ayLooking for a target!
		/varset myTargetID 0
		|-------------------
		/call TargetShortest
		|-- /message \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay] [\ap${myTargetIDLoc}\ay]		
		|/delay 1s
		|/echo \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay]
		|-------------------
	} else {
		/if (${Debugging}) /echo \ayI have an XTarget so I'm going to set that as my target.
		|---------------------------------------
		/if (${Me.XTarget}) {
			/varset myTargetID ${Target.ID}
			/if (${Debugging}) /echo CALL DoClearTargets
			/if (${Me.XTarget} || ${Spawn[id ${Target.ID}].Distance} < 30) /call DoClearTargets
			/if (${Debugging}) /echo END CALL DoClearTargets			
		}
		|---------------------------------------
	}
	:navto
	/if (${Debugging}) /echo DoSinglePull NAVTO
	/if (${Target.ID}) /squelch /target clear
	/if ((${Spawn[${myTargetID}].Distance} > 30 && !${Target.Type.Equal[corpse]} && !${Me.XTarget}) || !${Spawn[${myTargetID}].LineOfSight}) {
		/if (!${Spawn[${myTargetID}].ID}) {
			/squelch /target clear
			/if (${Debugging}) /echo \ar My target ID was null, so I'm returning out of the sub.
			/return
		}
		/varset BackUpTimer 0
		/message \agNavigating to: \ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agID: \ay[\ap${myTargetID}\ay] \agDistance: \ay[\ap${Spawn[${myTargetID}].Distance}\ay]
		/if (${Debugging}) /echo \ayNavigating to ${Spawn[${myTargetID}].Name} ID: ${myTargetID} Distance: ${Spawn[${myTargetID}].Distance} > 30 - Line of Sight: ${Spawn[${myTargetID}].LineOfSight}
		/call WaitNav ${myTargetID}
		/delay 10
		/if (${Debugging}) /echo Navigating to the enemy.
		/call SetLoc
		/call CheckStuck
		/delay 5
		/goto :navto
	} else /if (!${Target.ID} || ((${Target.ID}!=${myTargetID}) && (${Target.ID}!=${Me.ID}) && (${myTargetID}!=0) && !${Me.XTarget})) {
		/target id ${myTargetID}
		/if (${Navigation.Active}) /nav stop
	}
	/delay 5
	|----------------------------------------------------------------------------------------------------
	/docommand ${If[${PullAbilityRange}>30,/stop,/stick moveback uw 10]}
	/if (${Spawn[${myTargetID}].Distance}<=30 && !${Spawn[${myTargetID}].Aggressive}) /squelch /attack on
	|----------------------------------------------------------------------------------------------------
	|-----------------------------------------------
	/if (${Debugging}) /echo DoSinglePull Sub Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: TargetShortest
| --------------------------------------------------------------------------------------------
Sub TargetShortest
	/if (${Debugging}) /echo Sub TargetShortest Entry

	/if (${UseClickBuffs}) /call Clickies_Buffs
	/declare MobsInRadius 	int 	local 	${SpawnCount[npc noalert 1 targetable radius ${CampRadius} zradius ${ZRadius} alert 10]}


	|- Makes scanning in big zones super efficient.
	/if (${MobsInRadius} > 5) {
		/varset MobsInRadius 5
	}
	/declare MobCounter 	int 	local 	0
	/declare MobID 			int 	local 	0
	/declare PathLength		float	local	0
	/declare MobIDDistance	float	local	0
	/declare PathCount		int		local	1
	/declare PathShortest	int 	local 	0
	/declare MobIDValid		int		local	0
	/if (${Resting}) /return

	/varset myTargetID 0
	/if (${MobsInRadius}) {
		/for MobCounter 1 to ${MobsInRadius}
		/varset MobID ${NearestSpawn[${MobCounter},npc targetable radius ${CampRadius} zradius ${ZRadius} alert 10 noalert 1].ID}

		|-- ORIGINAL LIST TO FILTER
		|/if (${Select[${Spawn[ID ${MobID}].Type},PET,AURA,BANNER,CAMPFIRE,CORPSE,CHEST,ITEM,TRIGGER,TRAP,TIMER,MOUNT,MERCENARY,OBJECT]} && !${Ini[${MobIgnore},${Zone.ShortName},Ignored].Find[ID ${MobID}]}) /continue

		|-- REVISED LIST TO FILTER
		/if (${Select[${Spawn[ID ${MobID}].Type},PC,Untargetable,Mount,Pet,Corpse,Chest,Trigger,Trap,Timer,Item,Mercenary,Aura,Object,Banner,Campfire,Flyer]} && !${Ini[${MobIgnore},${Zone.ShortName},Ignored].Find[ID ${MobID}]}) /continue

		|-- Filter out anything without an actual CleanName ( DOORS )
		/if (!${Spawn[ID ${MobID}].CleanName.Length}) /continue

		|-- Filter out anything with an actual Surname   ( Named )
		/if (${Spawn[ID ${MobID}].Surname.Length}) /continue

		|------- HARD CODED EXCEPTIONS
		|/if (${Spawn[ID ${MobID}].CleanName.Equal[a hatchling]} || ${Spawn[ID ${MobID}].CleanName.Equal[a creaking crate]} || ${Spawn[ID ${MobID}].CleanName.Equal[a hollow tree]} || ${Spawn[ID ${MobID}].CleanName.Equal[a petrified colossal tree]}) {
		|/continue
		|}
		|------- HARD CODED EXCEPTIONS

		/varset MobIDValid 0
		/varset PathLength ${Navigation.PathLength[id ${MobID}]}
		/if (${PathLength} > 0) {
			/if (${PathCount}==1) {
				/varset myTargetID ${MobID}
				/varset PathShortest ${PathLength}
			} else /if (${PathLength} <= ${PathShortest}) {
				/varset myTargetID ${MobID}
				/varset PathShortest ${PathLength}
			}
			/varcalc PathCount ${PathCount}+1
		}

		/next MobCounter
		/if (${myTargetID}) /message \agPulling \ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agNPCID:\ay[\ap${myTargetID}\ay] \awat \ay[\at${PathShortest}\ay] \awfeet.
		/varset Announce FALSE
		/varset notkillable 0
	} else {
		/varset myTargetID 0
		/delay 5s ${Me.XTarget} == 0
		/if (!${Me.XTarget}) {
			/if (!${Announce}) {
				/message No more mobs to pull, lets Wait for Respawn!
				/varset Announce TRUE
			}
			/varset notkillable 0
			/if (${Me.Standing} && !${Navigation.Active}) /sit
		}
		/if (${Me.XTarget}) /return
	}
	/delay 1
	/if (${Debugging}) /echo Sub TargetShortest exit
	/varcalc BackUpTimer (${BackUpTimer})+1
	/if (${Debugging}) /echo Setting BackUpTimer +1 to ${BackUpTimer}
	/if (${Debugging} && ${BackUpTimer}>1) /echo \arCould Be Stuck ${BackUpTimer}
	|------------------------
	/if (${BackUpTimer}>10) {
		/if (!${Me.XTarget}) /call ReturnToCamp
		/delay 1s
		/message \ayHaving trouble getting to a target.. Attempting to get back on mesh.
		/if (${Debugging}) /echo Setting BackUpTimer Plus 1
		/call BackUp
		/delay 1s
		/varset BackUpTimer 0
	}
	|------------------------

	/if (${Debugging}) /echo Sub TargetShortest Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SwarmPullStepMove_1   Receive: SpawnPull_Step from Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------------
Sub SwarmPullStepMove_1(string SpawnPull_Step)
	/declare x 						int 	local 	${SpawnPull_Step}
	/declare TempSpawnPull_Loc		string 	local	NULL

	/if (${Debugging}) /echo Sub SwarmPullStepMove_1 Entry
	/if (${Debugging}) /echo SpawnPull_Loc=(${SpawnPull_Loc}) | SpawnPull_Step=(${SpawnPull_Step})

	/message ==================================================================
	/message \ag+++\ax \ayStarting \arSpawnPull \atPathTo \agCycle:\ax \ao...\ax \arLets go !\ax
	/message ==================================================================

	|----------------------------------------------------------------------------------------------
    /for x ${SpawnPull_Step} to ${LocalStepArray_${Zone.ShortName}_1.Size}
		/varset TempSpawnPull_Loc ${LocalStepArray_${Zone.ShortName}_1[1,${x}]}
		|-----------------------------
		/if (${TempSpawnPull_Loc.Equal[NULL]}) {
			/message \ar The Catacomb steps did not load correctly, reloading !
			/call DoSwarmPull_PathTo
			/delay 10
		}
		|-----------------------------

		|------------------------------------------
		/if (!${Me.XTarget} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
		}
		|------------------------------------------

		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/message \at - Calling the group to me before moving to the next step . . . .
		/call GroupWait
		/delay 1s
		|------------------------------------------

		|-------------------------
		/call CheckCasting
		|-------------------------

		|-----------------------------------------------
		|/echo \arSwarmPullStepMove: \ayTempSpawnPull_Loc=(${TempSpawnPull_Loc})
		|-----------------------------------------------
		/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
		/if (${TempSpawnPull_Loc.Length}>0 && ${DranikCExpedition}==1 && ${InADungeon}==1) {
			/message \agNext location to Nav to is: \aySTEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_1.Size}\ay] Coordinates: [\am${TempSpawnPull_Loc}\ay]
			|--------------------------------------------------------------
			|/echo \agARRAY RETURNED DATA for step \ay[${x}]\ag: TempSpawnPull_Loc=(\am${TempSpawnPull_Loc})
			|--------------------------------------------------------------
			/if (!${Me.Combat} && !${Me.XTarget} && (${InADungeon}==1) && (${DranikCExpedition}==1)) {
				|----------------------------------------------
				|-- Just nav to loc, using NavToLoc function will cause you to engage mobs along the path !
				|----------------------------------------------
				/squelch /nav loc ${TempSpawnPull_Loc}
				/delay 7
				/squelch /e3bcgza /nav loc ${TempSpawnPull_Loc}					
				|----------------------------------------------
			}
			|--------------------------------------------------------------
			/while (${Navigation.Active}) {
				/call SetLoc
				/call CheckStuck
				/delay 5
			}
			/squelch /e3bcgz /nav id ${Me.ID}
			/delay 5
			|----------------------------------------------------------

			|-------------------------------------------------------------------------------------------------------
			|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
			|-------------------------------------------------------------------------------------------------------
			/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
			/call IniChange "Theme" "LastSwarmed_Step" ${x}
			|-------------------------------------------------------------------------------------------------------

			|---------------------------------------------------------------
			| Use the DoClearTargets for SPawnPull system instead, of COMBAT
			|---------------------------------------------------------------
			/if (${Me.XTarget}) /call DoClearTargets
			/doevents
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.	
		/if (${LootCorpse} && !${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------
		/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
    /next x
	|----------------------------------------------------------------------------------------------

	|------------------
	/if (${ReclaimDC}) /call ReclaimAltDC
	|------------------

	|------------------------------------------
	/if (!${Me.XTarget} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}
	|------------------------------------------

	/message ==================================================================
	/message \atCompleted all SwarmPull "PathTo" steps.\ax
	/message \atUpdating (\ay${IniFileName})\ax INI file with PathTo completion.\ax
	/call IniChange "Theme" "CompletedPathTo" "TRUE"
	/call ForceSpawnStepReset
	/varset SpawnPull_Step 1
	/message \ayStarting Main Cycle Run !!!\ax
	/message ==================================================================
	/delay 3s
	|------------------------------------------------------
	/if (!${BiggerSwarms}) {
		/call DoSwarmPull_MainLoop
	} else {
		/call DoSwarmPull_MainLoop_Bigger
	}
	|------------------------------------------------------
	/delay 10

	/if (${Debugging}) /echo Sub SwarmPullStepMove_1 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SwarmPullStepMove_2   Receive: SpawnPull_Step from Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------------
Sub SwarmPullStepMove_2(string SpawnPull_Step)
	/declare x 						int 	local 	${SpawnPull_Step}
	/declare TempSpawnPull_Loc		string 	local	NULL
	/declare mStrLoc				string	local	NULL
	/declare mNavLocY				int		local	NULL
	/declare mNavLocX				int		local	NULL
	/declare SpawnsAtStep			int		local	NULL
	/declare CampReturnLoc			string	local	1905.66 336.42 -134.67

	/if (${Debugging}) /echo Sub SwarmPullStepMove_2 Entry
	/if (${Debugging}) /echo SpawnPull_Loc=(${SpawnPull_Loc}) | SpawnPull_Step=(${SpawnPull_Step})

	:MainLoopCycle
	/delay 1s
	/message ==================================================================
	/message \ag+++\ax \ayStarting \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \arLets go !\ax
	/message ==================================================================
	/delay 3s
	|-------------------------------------------------------------------------------------------------------
    /for x ${SpawnPull_Step} to ${LocalStepArray_${Zone.ShortName}_2.Size}
		/varset TempSpawnPull_Loc ${LocalStepArray_${Zone.ShortName}_2[1,${x}]}
		|-----------------------------
		/if (${TempSpawnPull_Loc.Equal[NULL]}) {
			/message \ar The Catacomb steps did not load correctly, reloading !
			/call DoSwarmPull_MainLoop
			/delay 1s
		}
		|-----------------------------

		|------------------------------------------
		/varset mNavLocY ${TempSpawnPull_Loc.Arg[1, ]}
		/varset mNavLocX ${TempSpawnPull_Loc.Arg[2, ]}
		|-------------------------
		/if (${mNavLocY}>=0) {
            /varset mStrLoc ${mNavLocX} ${mNavLocY}
        } else {
            /varset mStrLoc (${mNavLocX} ${mNavLocY})
        }
		 |-------------------------
		/varset SpawnsAtStep ${SpawnCount[npc loc ${mNavLocX} ${mNavLocY} radius 100]}
		|/echo SpawnsAtStep=(${SpawnsAtStep})
		|/echo  mStrLoc=(${mStrLoc}) | mNavLocY=(${mNavLocY}) | mNavLocYX(${mNavLocX})
		|------------------------------------------

		|------------------------------------------
		/if (!${Me.XTarget} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
		}
		|------------------------------------------

		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/message \at - Calling the group to me before moving to the next step . . . .
		/call GroupWait
		/delay 1s
		|------------------------------------------

		|-------------------------
		/call CheckCasting
		|-------------------------

		|-----------------------------------------------
		|/echo \arSwarmPullStepMove: \ayTempSpawnPull_Loc=(${TempSpawnPull_Loc})
		|-----------------------------------------------
		/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
		/if (${TempSpawnPull_Loc.Length}>0 && ${DranikCExpedition}==1 && ${InADungeon}==1) {
			/message \agNext location to Nav to is: \aySTEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_2.Size}\ay] Coordinates: [\am${TempSpawnPull_Loc}\ay]
			|-----------------------------------------------------------------------------------------------------------------------------
			/if (${SpawnsAtStep}>=1) {
				/message \ao - STEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_2.Size}\ay] has \at*\ay[\ar${SpawnsAtStep}\ay]\at* \ayspawns, \agKILL THEM ALL\ax \ao!!!\ax
				|--------------------------------------------------------------
				|/echo \agARRAY RETURNED DATA for step \ay[${x}]\ag: TempSpawnPull_Loc=(\am${TempSpawnPull_Loc})
				|--------------------------------------------------------------
				/if (!${Me.Combat} && !${Me.XTarget} && (${InADungeon}==1) && (${DranikCExpedition}==1)) {
					|----------------------------------------------
					|-- Just nav to loc, using NavToLoc function will cause you to engage mobs along the path !
					|----------------------------------------------
					/squelch /nav loc ${TempSpawnPull_Loc}
					/delay 7
					/squelch /e3bcgza /nav loc ${TempSpawnPull_Loc}
					|----------------------------------------------
				}
				|------------------------------
				/while (${Navigation.Active}) {
					/call SetLoc
					/call CheckStuck
					/delay 5
				}
				|------------------------------
				/squelch /e3bcgz /nav id ${Me.ID}
				/delay 5
				|----------------------------------------------------------

				|-------------------------------------------------------------------------------------------------------
				|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
				|-------------------------------------------------------------------------------------------------------
				/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
				/call IniChange "Theme" "LastSwarmed_Step" ${x}
				|-------------------------------------------------------------------------------------------------------
			} else {
				/message \ao - STEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_2.Size}\ay] has [\at${SpawnsAtStep}\ay] spawns, \arSKIPPING\ax \ao!!!\ax
				|-------------------------------------------------------------------------------------------------------
				|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
				|-------------------------------------------------------------------------------------------------------
				/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
				/call IniChange "Theme" "LastSwarmed_Step" ${x}
				|-------------------------------------------------------------------------------------------------------
			}
			|-----------------------------------------------------------------------------------------------------------------------------
			|---------------------------------------------------------------
			| Use the DoClearTargets for SPawnPull system instead, of COMBAT
			|---------------------------------------------------------------
			/if (${Me.XTarget}) /call DoClearTargets
			/doevents
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.	
		/if (${LootCorpse} && !${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------
		/if (!${Me.Combat} && !${Me.XTarget}) /call CheckExpeditionStatus
    /next x
	|-------------------------------------------------------------------------------------------------------

	| --- NAV TO CampReturnLoc
	/message ==================================================================
	/message \ag+++\ax \aoCompleted \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \atRETURNING TO CAMP !!!\ax
	/message ==================================================================

	|---------------		
	|-- MOVE TO CAMP
	|---------------		
	|-------------------------------
	/call NavToLoc2 ${CampReturnLoc}
	|-------------------------------
	
	:WaitTillAtCamp
	/if (${Me.Moving}) /delay 5
	/if (${Me.Moving}) /goto :WaitTillAtCamp
	
	|----------------------------------------------------------------
	|-- Clear the camp location of any corpses before the next cycle.
	|----------------------------------------------------------------
	/if (${LootCorpse} && !${Me.XTarget} && !${Bool[${Spawn[npc radius 35].Aggressive}]}) /call CheckForCorpses
	|----------------------------------------------------------------

	|------------------
	/if (${ReclaimDC}) /call ReclaimAltDC
	|------------------

	|------------------------------------------
	/if (!${Me.XTarget} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}
	|------------------------------------------

	/message ==================================================================
	/message \ag+++\ax \aoCompleted \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \agLets do it again !!!\ax
	/message ==================================================================
	/delay 3s
	|------------------------
	/call ForceSpawnStepReset
	/call Go2LastSwarmLoc
	|------------------------

	/goto :MainLoopCycle

	|----------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo Sub SwarmPullStepMove_2 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Go2LastSwarmLoc     ( Always Call This to pick up From LastSwarmed_Step )
| --------------------------------------------------------------------------------------------
Sub Go2LastSwarmLoc
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Entry
	|------------------------------------------------------------------------------------------------------------
	|- READ:  LastSwarmed_Dungeon and LastSwarmed_Step from ini file, to pickup at this point if restarted macro.
	|------------------------------------------------------------------------------------------------------------
	/varset LastSwarmed_Dungeon ${Ini[${IniFileName},Theme,LastSwarmed_Dungeon]}
	/varset LastSwarmed_Step ${Ini[${IniFileName},Theme,LastSwarmed_Step]}
	|-------------------------------------------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ayLastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})
	|-------------------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo LastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})
	/message \agThe last known spawn pull \aySTEP\ag is: \ay[\am${LastSwarmed_Step}\ay]

	|--------------------------------------------------------------------------------------------------------------------------
	| - Call the SwarmPullStepMove function and pass the location and step from INI file
	| - (The Array Values have already defined from DoSwarmPull)
	| -
	| If we are in same dungeon, pickup from LastSwarmed_Loc .. else..  run the path fresh !
	| SwarmPullStepMove will pick up the path in a loop where the step number will change X in the loop !
	|--------------------------------------------------------------------------------------------------------------------------
	|/echo {Zone.ShortName}=(${Zone.ShortName}) | {Ini.File.Zone.Name}=(${LastSwarmed_Dungeon})
	|-----------------------------------------------------------------------
	| Change values to pass STEP 1 if we arent in the last recorded dungeon.
	|-----------------------------------------------------------------------
	/if (!${Zone.ShortName.Equal[${LastSwarmed_Dungeon}]}) {
		/call ForceSpawnStepReset
	}
	|-----------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ay/call SwarmPullStepMove ${LastSwarmed_Step}
	|-----------------------------------------------------------------------

	|-----------------------------------
	|- Retrieve the last mission results
	|-----------------------------------
	/varset CompletedPathTo ${Ini[${IniFileName},Theme,CompletedPathTo]}
	|-----------------------------------
	/if (!${CompletedPathTo}) {
		/call SwarmPullStepMove_1 ${LastSwarmed_Step}
	} else {
		/call SwarmPullStepMove_2 ${LastSwarmed_Step}
	}
	|-----------------------------------------------------------------------

	|--------------------------------------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: ForceSpawnStepReset
| --------------------------------------------------------------------------------------------------
Sub ForceSpawnStepReset
/if (${Debugging}) /echo Sub ForceSpawnStepReset Entry
	
	/message \arForcing LastSwarmed_Step reset to step \ay(\at1\ay)
	
	|----------------------------------------------------------
	| -- Write STEP 1 to the ini file since we want to set our initial first step for that zone.
	|------------------------------------------
	/call IniChange "Theme" "LastSwarmed_Step" 1
	/varset LastSwarmed_Step 1
	/delay 20
	|------------------------------------------

/if (${Debugging}) /echo Sub ForceSpawnStepReset Exit
/return
| --------------------------------------------------------------------------------------------------

